# Set to true to use built-in mock data (no backend required)
VITE_USE_MOCK_DATA=true

# Backend API base URL (only needed when VITE_USE_MOCK_DATA=false)
# In development, Vite proxies /v1 -> http://localhost:8000/v1 automatically.
# In production, set this to your Railway backend URL.
VITE_API_URL=
