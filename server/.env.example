# ── Required for backend database ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/carbonlens?retryWrites=true&w=majority

# ── Optional — leave blank until keys are ready ──────────────────────────────
# NREL_API_KEY=           # https://developer.nrel.gov/signup/
# EIA_API_KEY=            # https://www.eia.gov/opendata/
# ANTHROPIC_API_KEY=      # https://console.anthropic.com/
GEMINI_API_KEY=          # https://aistudio.google.com/app/apikey  (free tier — 15 RPM / 1M tokens/day)
# CHROMA_PATH=./chroma_db  # local ChromaDB storage path (default: ./chroma_db)

# ── CORS — comma-separated allowed origins ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
